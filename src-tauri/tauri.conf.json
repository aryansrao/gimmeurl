{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GimmeURL",
  "version": "2.0.0",
  "identifier": "com.gimmeurl.dev",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "GimmeURL",
        "width": 960,
        "height": 720,
        "minWidth": 840,
        "minHeight": 620,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/32x32.png","icons/128x128.png","icons/128x128@2x.png","icons/icon.icns","icons/icon.ico"]
  },
  "plugins": {
    "shell": { "open": true }
  }
}
